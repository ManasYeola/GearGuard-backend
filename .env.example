# .env.example - Copy this to .env and update with your values

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=gearguard
DB_PORT=3306

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRE=30d

# Email Notifications (Nodemailer / SMTP)
# Notifications are enabled by default when SMTP values are present.
# Set EMAIL_NOTIFICATIONS_ENABLED=false to disable mail delivery.
EMAIL_NOTIFICATIONS_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
EMAIL_FROM="GearGuard Notifications <no-reply@yourdomain.com>"
FRONTEND_URL=http://localhost:3000
